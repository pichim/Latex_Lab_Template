% slidesstyle.sty -- beamer slide style aligned with labstyle.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{slidesstyle}[2026/04/25 v1.5 Lab-aligned beamer slide style]

% -----------------------------------------------------------------------------
% Alignment Notes (slidesstyle <-> labstyle)
% -----------------------------------------------------------------------------
% Shared customization hooks (same names in both files):
%   \labtitlecolor, \labsubtitlecolor, \labheadingcolor, \lablistlabelcolor
%   \lablinkcolor, \labcitecolor, \laburlcolor
%   \labtextcolor, \labpagecolor
%   \labheadlinefgcolor, \labheadlinebgcolor
%   \labfootlinefgcolor, \labfootlinebgcolor
%   \labblocktitlecolor, \labblockbodycolor, \labblockbgcolor
%   \labheader, \labfooter, \lablogo, \lablogoheight, \lablogotoptrim
%   \labheaderoffset, \labfootersize
%
% Slidesstyle-specific behavior:
%   - no answerbox environments (labstyle-only)
%   - headline/footline colors map directly to Beamer color boxes
%
% Class-level differences (expected):
%   - slidesstyle uses Beamer templates and color themes
%   - labstyle uses KOMA-Script page style and tcolorbox answer areas

% -----------------------------------------------------------------------------
% Engine + fonts
% -----------------------------------------------------------------------------
\RequirePackage{iftex}
\ifPDFTeX
    \RequirePackage[T1]{fontenc}
    \RequirePackage[utf8]{inputenc}
    \RequirePackage{lmodern}
\else
    \RequirePackage{fontspec}
    \setmainfont{TeX Gyre Pagella}
    \setsansfont{TeX Gyre Heros}
    \IfFontExistsTF{JetBrains Mono}
    {\setmonofont{JetBrains Mono}}
    {\setmonofont{TeX Gyre Cursor}}
\fi

% -----------------------------------------------------------------------------
% Core packages
% -----------------------------------------------------------------------------
\RequirePackage{microtype}
\RequirePackage{graphicx}
\RequirePackage[dvipsnames]{xcolor}
\RequirePackage{siunitx}
\RequirePackage{amsmath,amssymb}
\RequirePackage{booktabs}
\RequirePackage{etoolbox}
\RequirePackage{hyperref}
\makeatletter
\AtEndPreamble{%
    \@ifpackageloaded{csquotes}{}{% load after babel/polyglossia when possible
        \RequirePackage{csquotes}%
    }%
}
\makeatother

\sisetup{
    per-mode = symbol,
    range-units = single
}
% -----------------------------------------------------------------------------
% Paths / Colors
% -----------------------------------------------------------------------------
\graphicspath{{figures/}{Figures/}}
\definecolor{blueColor}{RGB}{0,100,166}
\definecolor{greyColor}{RGB}{90, 90, 90}
\definecolor{orangeColor}{RGB}{225, 85, 0}
\definecolor{blackColor}{RGB}{0, 0, 0}
\definecolor{whiteColor}{RGB}{255, 255, 255}

% Semantic color hooks (override in main .tex via \renewcommand).
% Shared names with labstyle.sty are kept intentionally.
\newcommand{\labtitlecolor}{blueColor}
\newcommand{\labsubtitlecolor}{blueColor}
\newcommand{\labheadingcolor}{blueColor}
\newcommand{\lablistlabelcolor}{blueColor}
\newcommand{\lablinkcolor}{NavyBlue}
\newcommand{\labcitecolor}{RoyalBlue}
\newcommand{\laburlcolor}{RoyalBlue}

\newcommand{\labtextcolor}{blackColor}
\newcommand{\labpagecolor}{whiteColor}
\newcommand{\labheadlinefgcolor}{blackColor}
\newcommand{\labheadlinebgcolor}{whiteColor}
\newcommand{\labfootlinefgcolor}{whiteColor}
\newcommand{\labfootlinebgcolor}{greyColor}
\newcommand{\labblocktitlecolor}{blueColor}
\newcommand{\labblockbodycolor}{blackColor}
\newcommand{\labblockbgcolor}{whiteColor}

% -----------------------------------------------------------------------------
% Beamer look
% -----------------------------------------------------------------------------
\mode<presentation>{
    \usetheme{default}
    \usefonttheme{serif}
    \setbeamertemplate{navigation symbols}{}
}

\hypersetup{
    colorlinks=true,
    linkcolor=\lablinkcolor,
    citecolor=\labcitecolor,
    urlcolor=\laburlcolor
}
\urlstyle{same}

\setbeamercolor{normal text}{fg=\labtextcolor,bg=\labpagecolor}
\setbeamercolor{structure}{fg=\labheadingcolor}
\setbeamercolor{alerted text}{fg=\labheadingcolor}
\setbeamercolor{title}{fg=\labtitlecolor}
\setbeamercolor{subtitle}{fg=\labsubtitlecolor}
\setbeamercolor{frametitle}{fg=\labheadingcolor,bg=\labpagecolor}
\setbeamercolor{block title}{fg=\labblocktitlecolor,bg=\labblockbgcolor}
\setbeamercolor{block body}{fg=\labblockbodycolor,bg=\labblockbgcolor}
\setbeamercolor{section title}{fg=\labheadingcolor,bg=\labpagecolor}
\setbeamercolor{headline text}{fg=\labheadlinefgcolor,bg=\labheadlinebgcolor}
\setbeamercolor{footline text}{fg=\labfootlinefgcolor,bg=\labfootlinebgcolor}

\setbeamerfont{title}{series=\bfseries,size=\Large}
\setbeamerfont{subtitle}{series=\mdseries,size=\normalsize}
\setbeamerfont{frametitle}{series=\bfseries,size=\normalsize}
\setbeamerfont{normal text}{size=\small}
\setbeamerfont{author}{size=\small}
\setbeamerfont{institute}{size=\small}
\setbeamerfont{date}{size=\small}
\setbeamerfont{itemize/enumerate body}{size=\small}
\setbeamerfont{itemize/enumerate subbody}{size=\footnotesize}
\setbeamerfont{itemize/enumerate subsubbody}{size=\scriptsize}
\setbeamerfont{block title}{size=\small}
\setbeamerfont{block body}{size=\small}

% -----------------------------------------------------------------------------
% Metadata (override in main .tex)
% -----------------------------------------------------------------------------
\newcommand{\labheader}{RT I}      % top-left text
\newcommand{\labfooter}{ZHAW / IMS}  % bottom-left text
\newcommand{\lablogo}{imslogo.pdf} % image filename for top-right (set empty to hide)
\newcommand{\lablogoheight}{5.0ex} % logo height in header
\newcommand{\lablogotoptrim}{50mm} % trim amount from top (trim = l b r t)
\newcommand{\labheaderoffset}{3ex} % positive raises left header text
\newcommand{\labfootersize}{\footnotesize}

% -----------------------------------------------------------------------------
% Math helpers
% -----------------------------------------------------------------------------
\newcommand{\dd}{\mathrm{d}}
\newcommand{\e}{\mathrm{e}}

% -----------------------------------------------------------------------------
% List defaults
% -----------------------------------------------------------------------------
% Match labstyle spacing as closely as Beamer permits.
\setbeamertemplate{itemize item}{\color{\lablistlabelcolor}$\bullet$}
\setbeamertemplate{itemize subitem}{\color{\lablistlabelcolor}$\bullet$}
\setbeamertemplate{enumerate item}{\color{\lablistlabelcolor}\insertenumlabel.}
\setbeamertemplate{enumerate subitem}{\color{\lablistlabelcolor}\insertsubenumlabel.}
\setbeamertemplate{enumerate subsubitem}{\color{\lablistlabelcolor}\insertsubsubenumlabel.}

% -----------------------------------------------------------------------------
% Header / Footer
% -----------------------------------------------------------------------------
\setbeamertemplate{headline}{%
    \leavevmode
    % Pull header upward and keep its footprint compact.
    \vskip-0.8ex
    \begin{beamercolorbox}[wd=\paperwidth,ht=7.56ex,dp=0.72ex,leftskip=1em,rightskip=1em]{headline text}
        {\raisebox{\labheaderoffset}{\scriptsize\bfseries \labheader}}\hfill
        \ifdefempty{\lablogo}{}{
            \IfFileExists{\lablogo}{%
                \includegraphics[height=\lablogoheight,trim=0 0 0 \lablogotoptrim,clip]{\lablogo}%
            }{}%
        }
    \end{beamercolorbox}
}

\setbeamertemplate{footline}{%
    \leavevmode
    \begin{beamercolorbox}[wd=\paperwidth,ht=3.2ex,dp=1.2ex,leftskip=1em,rightskip=1em]{footline text}
        {\labfootersize \labfooter}\hfill
        \insertframenumber/\inserttotalframenumber
    \end{beamercolorbox}
}

% -----------------------------------------------------------------------------
% Title / Section pages
% -----------------------------------------------------------------------------
\setbeamertemplate{title page}{%
    \vbox{}%
    \vfill
    {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}
    \vspace{0.6em}
    {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}
    \vspace{1.2em}
    {\insertauthor\par}
    {\insertinstitute\par}
    \vspace{0.5em}
    {\insertdate\par}
    \vfill
}

\setbeamertemplate{section page}{%
    \vfill
    \begin{centering}
        {\usebeamerfont{section title}\usebeamercolor[fg]{section title}\insertsection\par}
    \end{centering}
    \vfill
}

% Helper macro for a standalone section divider frame.
\newcommand{\labsectionframe}{%
    \begin{frame}[plain]
        \sectionpage
    \end{frame}
}

% labstyle.sty -- lab handout style
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{labstyle}[2026/03/08 v1.6 Lab handout style]

% -----------------------------------------------------------------------------
% Alignment Notes (labstyle <-> slidesstyle)
% -----------------------------------------------------------------------------
% Shared customization hooks (same names in both files):
%   \labtitlecolor, \labsubtitlecolor, \labheadingcolor, \lablistlabelcolor
%   \lablinkcolor, \labcitecolor, \laburlcolor
%   \labtextcolor, \labpagecolor
%   \labheadlinefgcolor
%   \labfootlinefgcolor
%   \labblocktitlecolor, \labblockbodycolor, \labblockbgcolor
%   \labheader, \labfooter, \lablogo, \lablogoheight, \lablogotoptrim
%   \labheaderoffset, \labfootersize
%
% Labstyle-specific hook:
%   \labboxframecolor (answer box frame)
%
% Class-level differences (expected):
%   - labstyle uses KOMA-Script page style (no colored headline/footline bar box)
%   - slidesstyle uses Beamer color boxes for headline/footline areas

% -----------------------------------------------------------------------------
% Engine + fonts
% -----------------------------------------------------------------------------
\RequirePackage{iftex}
\ifPDFTeX
    \RequirePackage[T1]{fontenc}
    \RequirePackage[utf8]{inputenc}
    \RequirePackage{lmodern}
\else
    \RequirePackage{fontspec}
    \setmainfont{TeX Gyre Pagella}
    \setsansfont{TeX Gyre Heros}
    \IfFontExistsTF{JetBrains Mono}
    {\setmonofont{JetBrains Mono}}
    {\setmonofont{TeX Gyre Cursor}}
\fi

% -----------------------------------------------------------------------------
% Core packages
% -----------------------------------------------------------------------------
\RequirePackage{microtype}
\RequirePackage{graphicx}
\RequirePackage[dvipsnames]{xcolor}

\RequirePackage{siunitx}
\sisetup{
    per-mode = symbol,
    range-units = single
}

\RequirePackage{amsmath,amssymb}
\RequirePackage{booktabs}
\RequirePackage{enumitem}

\RequirePackage{hyperref}
\urlstyle{same}
\RequirePackage[nameinlink,capitalise]{cleveref}
\RequirePackage{etoolbox} % for \ifdefempty
\makeatletter
\AtEndPreamble{%
    \@ifpackageloaded{csquotes}{}{% load after babel/polyglossia when possible
        \RequirePackage{csquotes}%
    }%
}
\makeatother

% -----------------------------------------------------------------------------
% Paths / Colors
% -----------------------------------------------------------------------------
\graphicspath{{figures/}{Figures/}}
\definecolor{blueColor}{RGB}{0,100,166}
\definecolor{greyColor}{RGB}{90, 90, 90}
\definecolor{orangeColor}{RGB}{225, 85, 0}
\definecolor{blackColor}{RGB}{0, 0, 0}
\definecolor{whiteColor}{RGB}{255, 255, 255}

% Semantic color hooks (override in main .tex via \renewcommand).
\newcommand{\labtitlecolor}{blueColor}
\newcommand{\labsubtitlecolor}{blueColor}
\newcommand{\labheadingcolor}{blueColor}
\newcommand{\lablistlabelcolor}{blueColor}
\newcommand{\lablinkcolor}{NavyBlue}
\newcommand{\labcitecolor}{RoyalBlue}
\newcommand{\laburlcolor}{RoyalBlue}
\newcommand{\labtextcolor}{blackColor}
\newcommand{\labpagecolor}{whiteColor}
\newcommand{\labheadlinefgcolor}{blackColor}
\newcommand{\labfootlinefgcolor}{blackColor}
\newcommand{\labblocktitlecolor}{blueColor}
\newcommand{\labblockbodycolor}{blackColor}
\newcommand{\labblockbgcolor}{whiteColor}
\newcommand{\labboxframecolor}{greyColor}

\hypersetup{
    colorlinks=true,
    linkcolor=\lablinkcolor,
    citecolor=\labcitecolor,
    urlcolor=\laburlcolor
}

% List styling and spacing hooks.
% Defaults for the lab handout list spacing.
% Examples (put these in lab.tex preamble when customizing):
% \setlabitemizespacing{topsep=2pt,itemsep=4pt,parsep=1pt,partopsep=1pt}
% \setlabenumeratespacing{topsep=2pt,itemsep=4pt,parsep=1pt,partopsep=1pt}
\newcommand{\setlabitemizespacing}[1]{%
    \ifstrempty{#1}{%
        \setlist[itemize]{label=\textbullet,font=\color{\lablistlabelcolor}}%
    }{%
        \setlist[itemize]{label=\textbullet,font=\color{\lablistlabelcolor},#1}%
    }%
}
\newcommand{\setlabenumeratespacing}[1]{%
    \ifstrempty{#1}{%
        \setlist[enumerate]{font=\color{\lablistlabelcolor}}%
    }{%
        \setlist[enumerate]{font=\color{\lablistlabelcolor},#1}%
    }%
}
% \setlabitemizespacing{}
% \setlabenumeratespacing{}
\setlabitemizespacing{topsep=2pt,itemsep=2pt,parsep=1pt,partopsep=1pt}
\setlabenumeratespacing{topsep=2pt,itemsep=2pt,parsep=1pt,partopsep=1pt}

% Color sectioning commands for KOMA classes (e.g. scrartcl).
\makeatletter
\@ifundefined{addtokomafont}{}{\addtokomafont{disposition}{\color{\labheadingcolor}}}
\makeatother

\AtBeginDocument{%
    \pagecolor{\labpagecolor}%
    \color{\labtextcolor}%
}

% -----------------------------------------------------------------------------
% Metadata (override in main .tex)
% -----------------------------------------------------------------------------
\newcommand{\labtitle}{}
\newcommand{\labsubtitle}{}
\newcommand{\labauthor}{}
\newcommand{\labdate}{\today}

% -----------------------------------------------------------------------------
% Document layout defaults (override in main .tex if needed)
% -----------------------------------------------------------------------------
\newcommand{\labtopmarginadjust}{-2mm}

\makeatletter
\@ifundefined{KOMAoptions}{}{%
    \KOMAoptions{%
        parskip=half,
        headings=small,
        headinclude=true,
        footinclude=true
    }%
}
\@ifundefined{areaset}{}{%
    \areaset{175mm}{290mm}%
}
\makeatother
\AtBeginDocument{\addtolength{\topmargin}{\labtopmarginadjust}}

% Custom units shared across lab sheets.
\DeclareSIUnit{\rpm}{rpm}
\DeclareSIUnit{\newtonmeter}{\newton\metre}

% -----------------------------------------------------------------------------
% Title block
% -----------------------------------------------------------------------------
\makeatletter
\newcommand{\makelabtitle}{%
    \par\vspace*{0em}%
    {\LARGE\bfseries\color{\labtitlecolor} \labtitle\par}%
    \ifdefempty{\labsubtitle}{}{%
        {\Large\color{\labsubtitlecolor}\labsubtitle\par}%
    }%
    {\large \labauthor\quad\textendash\quad \labdate\par}
    \vspace{0em}\par
}
\makeatother

% -----------------------------------------------------------------------------
% Aufgaben environment
% -----------------------------------------------------------------------------
\newenvironment{aufgaben}[1][Aufgaben]{%
    \par\smallskip
    \begingroup
    \noindent\textbf{\color{\labblocktitlecolor}#1}\par\smallskip
    \color{\labblockbodycolor}
    \begin{enumerate}[leftmargin=*]
        }{%
    \end{enumerate}%
    \endgroup
    \par\smallskip
}

% -----------------------------------------------------------------------------
% Figure / Table helpers
% -----------------------------------------------------------------------------
\makeatletter
\newcommand{\labfig}[3][]{%
    \filename@parse{#2}% sets \filename@base
    \begin{figure}[htbp]
        \centering
        \includegraphics[#1]{#2}%
        \caption{#3}\label{fig:\filename@base}%
    \end{figure}
}
\makeatother

% Table helper: store caption text and place the caption below the table.
\makeatletter
\newcommand{\gentable@cap}{}% storage for caption text
\newenvironment{gentable}[2]{%
    \def\gentable@cap{#2}%
    \begin{table}[htbp]\centering
        \begin{tabular}{#1}\toprule
            }{%
            \bottomrule\end{tabular}%
        \caption{\gentable@cap}%
    \end{table}%
}
\makeatother

% -----------------------------------------------------------------------------
% Math helpers
% -----------------------------------------------------------------------------
\newcommand{\dd}{\mathrm{d}}
\newcommand{\e}{\mathrm{e}}

% -----------------------------------------------------------------------------
% Header / Footer
% -----------------------------------------------------------------------------
\RequirePackage{scrlayer-scrpage}
\clearpairofpagestyles
\pagestyle{scrheadings}
\setkomafont{pageheadfoot}{\normalfont}

\KOMAoptions{
    headsepline=.2pt:\textwidth,
    footsepline=false,
    headinclude=true,     % include header in type area calculation
    headheight=36pt       % satisfy minimum head height warning
}
\setlength{\headheight}{36pt}

% -----------------------------------------------------------------------------
% Header / Footer metadata (override in main .tex)
% -----------------------------------------------------------------------------
\newcommand{\labheader}{RT I}         % top-left text
\newcommand{\labfooter}{ZHAW / IMS}     % bottom-left text
\newcommand{\lablogo}{imslogo.pdf}    % small image filename for top-right (optional)
\newcommand{\lablogoheight}{5.0ex}    % logo height in header
\newcommand{\lablogotoptrim}{50mm}    % trim amount from top (trim = l b r t)
\newcommand{\labheaderoffset}{-0.3cm} % negative moves header text down
\newcommand{\labfootersize}{\footnotesize}
\newcommand{\labfootskip}{12mm}

\setlength{\footskip}{\labfootskip}

\makeatletter
\ihead{\small\color{\labheadlinefgcolor}\raisebox{\labheaderoffset}{\labheader}}
\ohead{%
    \ifdefempty{\lablogo}{}{%
        \IfFileExists{\lablogo}{\includegraphics[height=\lablogoheight,trim=0 0 0 \lablogotoptrim,clip]{\lablogo}}{}%
    }%
}
\ifoot{{\labfootersize\color{\labfootlinefgcolor} \labfooter}}
\ofoot{{\labfootersize\color{\labfootlinefgcolor} \pagemark}}
\makeatother

% -----------------------------------------------------------------------------
% Answer boxes (vertically scaled)
% -----------------------------------------------------------------------------
\RequirePackage[most]{tcolorbox} % loads TikZ
\usetikzlibrary{calc}            % required for coordinate math

\tcbset{
    labbox/.style={
            colframe=\labboxframecolor,
            colback=\labblockbgcolor,
            boxrule=0.8pt,
            arc=2pt,
            left=6pt,right=6pt,top=4pt,bottom=4pt,
        }
}

% Scale factor: 1.2x baseline (change 7/5 to adjust)
\newlength{\labrowskip}
\setlength{\labrowskip}{\dimexpr 7\baselineskip/5\relax} % 1.2x \baselineskip

% Fixed-height empty box (N lines tall with scaled line height)
\newenvironment{answerbox}[1][3]{%
    \begin{tcolorbox}[
            labbox, enhanced,
            width=\linewidth,
            height=\dimexpr #1\labrowskip + 8pt\relax, % + top/bottom padding (4pt each)
            valign=center
        ]%
        }{\end{tcolorbox}}

% Ruled variant: N lines of writing space with N-1 guide lines.
\newenvironment{answerboxruled}[1][3]{%
    \begin{tcolorbox}[
            labbox, enhanced,
            width=\linewidth,
            height=\dimexpr #1\labrowskip + 8pt\relax,
            overlay={%
                    \pgfmathtruncatemacro{\N}{#1-1}%
                    \foreach \i in {1,...,\N} {%
                            % Center each guide line within a writing row.
                            \pgfmathsetlengthmacro{\y}{(\i + 0.15) * \the\labrowskip}%
                            \draw[opacity=0.25]
                            ($(interior.south west) + (0pt,\y)$) --
                            ($(interior.south east) + (0pt,\y)$);
                        }%
                }
        ]%
        }{\end{tcolorbox}}

% Auto-height variant: fill remaining page space using the same row scale.
\makeatletter
\newlength{\ab@h}      % remaining vertical space
\newlength{\ab@tmp}    % scratch
\newcount\ab@N         % rows that fit
\newcommand*\ab@pad{8pt}% tcolorbox top+bottom padding (4pt each)

\newenvironment{answerboxfillpage}{%
    \par\begingroup
    \ifhmode\par\fi
    % Remaining height; at top-of-page \pagegoal=\maxdimen, so use \textheight.
    \setlength{\ab@h}{%
        \ifdim\pagegoal=\maxdimen \textheight\else \dimexpr\pagegoal-\pagetotal\relax\fi
    }%
    % Reserve a little headroom.
    \addtolength{\ab@h}{-\baselineskip}%
    % Fit an integer number of rows into the available space.
    \setlength{\ab@tmp}{\dimexpr \ab@h - \ab@pad\relax}%
    \ifdim\ab@tmp<0pt \setlength{\ab@tmp}{0pt}\fi
    \ab@N=0\relax
    \loop\ifdim\ab@tmp>\labrowskip
    \addtolength{\ab@tmp}{-\labrowskip}%
    \advance\ab@N by 1\relax
    \repeat
    % Optionally round up one row if leftover space is large.
    \ifdim\ab@tmp>.6\labrowskip \advance\ab@N by 1\relax\fi
    % Enforce a small minimum height.
    \ifnum\ab@N<3 \ab@N=3\fi
    % Final box height = rows * rowheight + padding.
    \setlength{\ab@h}{\dimexpr \ab@N\labrowskip + \ab@pad\relax}%
    \begin{tcolorbox}[labbox, enhanced,
            width=\linewidth, height=\ab@h, valign=top]%
        }{%
    \end{tcolorbox}\endgroup
}
\makeatother
